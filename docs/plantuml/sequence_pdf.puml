@startuml sequence_pdf
title DS-03 : Diagramme de Séquence — Génération PDF

skinparam backgroundColor #FEFEFE
skinparam sequenceArrowColor #2E86C1
skinparam sequenceParticipantBackgroundColor #D4E6F1

actor "USER" as User
participant "FactureDetail.js" as Detail
participant "pdfGenerator.js\n(downloadFacturePDF)" as PDFGen
participant "jsPDF\n(doc)" as JPDF
participant "jspdf-autotable\n(autoTable)" as AutoTable
participant "Navigateur\n(téléchargement)" as Browser

User -> Detail : Clic "Télécharger PDF"
Detail -> Detail : handleDownloadPDF()

alt Données complètes (facture + client + paramètres)
  Detail -> PDFGen : downloadFacturePDF(facture, client, articles, parametres)
  PDFGen -> JPDF : new jsPDF()

  PDFGen -> JPDF : Bordure dorée (line)
  PDFGen -> JPDF : En-tête entreprise (text: nom, adresse, SIRET)
  PDFGen -> JPDF : Bloc client (rect + text: nom, email, tel)
  PDFGen -> JPDF : Titre "FACTURE" + numéro, date, statut
  PDFGen -> JPDF : Rectangle fond gris (facture info)

  PDFGen -> AutoTable : autoTable(doc, {head, body, theme:'striped'})
  AutoTable --> PDFGen : tableau généré

  loop Pour chaque article
    PDFGen -> JPDF : Bloc détail prix (designation, qty, prix, remise, TVA, total)
  end

  PDFGen -> JPDF : Bloc totaux (Total HT)
  
  alt remise_globale > 0
    PDFGen -> JPDF : Ligne remise globale (rouge)
    PDFGen -> JPDF : Ligne total après remise
  end
  
  PDFGen -> JPDF : TVA (20%)
  PDFGen -> JPDF : Total TTC (or, gras)
  PDFGen -> JPDF : Conditions paiement
  PDFGen -> JPDF : Pied de page décoratif

  PDFGen -> JPDF : doc.save("Facture_INV-0615.pdf")
  JPDF -> Browser : Déclencher téléchargement fichier
  Browser --> User : Fichier PDF téléchargé

else Données manquantes
  Detail --> User : alert("Données manquantes - impossible de générer le PDF")
end

note right of PDFGen
  Génération 100% côté client
  Aucune donnée transmise au serveur
  Temps moyen : < 400ms
end note

@enduml
