@startuml usecase_global
title Diagramme de Cas d'Utilisation — Application Gestion des Factures

left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam backgroundColor #FEFEFE
skinparam usecase { BackgroundColor #D4E6F1 BorderColor #2E86C1 }

actor "USER\n(Comptable/Agent)" as USER
actor "ADMIN\n(Administrateur)" as ADMIN
actor "Firebase" as FB <<système>>
actor "JSON Server" as JS <<système>>

ADMIN -|> USER : <<hérite>>

rectangle "Application Web de Gestion des Factures" {

  package "Authentification" {
    usecase "Se connecter" as UC_LOGIN
    usecase "Se déconnecter" as UC_LOGOUT
  }

  package "Gestion Clients" {
    usecase "Consulter clients" as UC_LIST_CLI
    usecase "Créer un client" as UC_CREATE_CLI
    usecase "Modifier un client" as UC_EDIT_CLI
    usecase "Supprimer un client" as UC_DEL_CLI
  }

  package "Gestion Factures" {
    usecase "Créer une facture" as UC_CREATE_FAC
    usecase "Modifier une facture" as UC_EDIT_FAC
    usecase "Consulter liste factures" as UC_LIST_FAC
    usecase "Voir détail facture" as UC_DETAIL_FAC
    usecase "Calculer totaux auto" as UC_CALC
    usecase "Appliquer remises" as UC_REMISES
    usecase "Suivre paiements" as UC_PAIE
    usecase "Valider une facture" as UC_VALID
    usecase "Supprimer une facture" as UC_DEL_FAC
  }

  package "PDF" {
    usecase "Générer PDF" as UC_PDF
  }

  package "Dashboard" {
    usecase "Consulter tableau de bord" as UC_DASH
    usecase "Voir graphique CA mensuel" as UC_GRAPH
  }

  package "Administration (ADMIN)" {
    usecase "Gérer articles" as UC_ARTICLES
    usecase "Gérer catégories" as UC_CATEG
    usecase "Configurer paramètres" as UC_PARAMS
  }
}

' Relations USER
USER --> UC_LOGIN
USER --> UC_LOGOUT
USER --> UC_LIST_CLI
USER --> UC_CREATE_CLI
USER --> UC_EDIT_CLI
USER --> UC_CREATE_FAC
USER --> UC_EDIT_FAC
USER --> UC_LIST_FAC
USER --> UC_DETAIL_FAC
USER --> UC_SUIVRE_PAIE
USER --> UC_PDF
USER --> UC_DASH

' Relations ADMIN supplémentaires
ADMIN --> UC_DEL_CLI
ADMIN --> UC_VALID
ADMIN --> UC_DEL_FAC
ADMIN --> UC_ARTICLES
ADMIN --> UC_CATEG
ADMIN --> UC_PARAMS
ADMIN --> UC_GRAPH

' Include relations
UC_CREATE_FAC ..> UC_CALC : <<include>>
UC_CREATE_FAC ..> UC_REMISES : <<include>>
UC_EDIT_FAC ..> UC_CALC : <<include>>
UC_DASH ..> UC_GRAPH : <<include>>

' Extend relations
UC_VALID ..> UC_DETAIL_FAC : <<extend>>
UC_DEL_FAC ..> UC_LIST_FAC : <<extend>>

' Systèmes
FB <-- UC_CREATE_FAC
FB <-- UC_CREATE_CLI
JS <-- UC_ARTICLES
JS <-- UC_CATEG
JS <-- UC_PARAMS

@enduml
