# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/gestion-factures
# Ou MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/gestion-factures?retryWrites=true&w=majority

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Secret (générez-en un unique pour votre projet)
JWT_SECRET=votre_secret_jwt_tres_securise_changez_moi

# CORS Origin (URL du frontend)
CORS_ORIGIN=http://localhost:3000
